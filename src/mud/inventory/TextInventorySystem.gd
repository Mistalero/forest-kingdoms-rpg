# Отображение инвентаря игрока
func display_inventory():
	# Здесь должна быть логика получения инвентаря игрока
	# и отображения его текстового представления
	
	print("Ваш инвентарь:")
	
	# Пример содержимого инвентаря
	var items = [
		{"name": "длинный меч", "type": "оружие", "damage": 10},
		{"name": "кожаная броня", "type": "броня", "protection": 5},
		{"name": "целебное зелье", "type": "расходуемый", "heal": 20}
	]
	
	if items.size() == 0:
		print("  Ваш инвентарь пуст.")
	else:
		for i in range(items.size()):
			var item = items[i]
			print("  " + str(i+1) + ". " + item.name)
	
	print("")

