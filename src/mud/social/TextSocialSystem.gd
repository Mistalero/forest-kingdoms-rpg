# TextSocialSystem.gd
# Класс для текстовой системы социальных взаимодействий в MUD режиме

extends Node

# Отправка сообщения в чат
func send_message(message: String):
	# Здесь должна быть логика отправки сообщения в чат
	
	print("Вы говорите: "" + message + """)
	
	# Здесь должна быть логика отправки сообщения другим игрокам
	# через P2P сеть

# Отправка приватного сообщения игроку
func send_private_message(player_name: String, message: String):
	# Здесь должна быть логика отправки приватного сообщения игроку
	
	print("Вы шепчете " + player_name + ": "" + message + """)
	
	# Здесь должна быть логика отправки приватного сообщения указанному игроку
	# через P2P сеть

# Выполнение эмоции
func perform_emote(action: String):
	# Здесь должна быть логика выполнения эмоции
	
	print("Вы " + action)
	
	# Здесь должна быть логика отображения эмоции другим игрокам
	# через P2P сеть

# Отображение списка онлайн игроков
func display_online_players():
	# Здесь должна быть логика получения списка онлайн игроков
	
	print("Онлайн игроки:")
	
	# Пример списка игроков
	var players = ["Артур", "Мерлин", "Ланселот"]
	
	for i in range(players.size()):
		print("  " + players[i])
	
	print("")

# Приглашение игрока в группу
func invite_to_group(player_name: String):
	# Здесь должна быть логика отправки приглашения в группу игроку
	
	print("Вы пригласили " + player_name + " в группу")
	
	# Здесь должна быть логика отправки приглашения указанному игроку
	# через P2P сеть

# Принятие приглашения в группу
func accept_group_invite(inviter_name: String):
	# Здесь должна быть логика принятия приглашения в группу
	
	print("Вы приняли приглашение от " + inviter_name + " в группу")
	
	# Здесь должна быть логика присоединения к группе

# Отклонение приглашения в группу
func decline_group_invite(inviter_name: String):
	# Здесь должна быть логика отклонения приглашения в группу
	
	print("Вы отклонили приглашение от " + inviter_name + " в группу")
	
	# Здесь должна быть логика уведомления отправителя об отказе